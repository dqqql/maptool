{
  "name": "trpg-maptool",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "面向 GM 的 TRPG 世界整理工具 —— 黑白手绘 + 羊皮纸风无限画布",
  "scripts": {
    "dev": "concurrently --kill-others-on-fail --names web,api \"npm:dev:web\" \"npm:dev:api\"",
    "dev:web": "vite",
    "predev:api": "vite build --outDir .wrangler/dev-assets --emptyOutDir",
    "dev:api": "wrangler pages dev .wrangler/dev-assets --port 8788 --show-interactive-dev-session=false",
    "test:functions": "vitest run --config functions/vitest.config.ts",
    "typecheck": "tsc -b && tsc -p functions/tsconfig.json",
    "build": "npm run typecheck && vite build && vite build --config vite.viewer.config.ts",
    "preview": "vite preview"
  },
  "dependencies": {
    "idb": "^8.0.0",
    "konva": "^9.3.6",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-konva": "^18.2.10",
    "react-router-dom": "^6.26.2",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260613.1",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^9.2.1",
    "playwright": "^1.60.0",
    "typescript": "^5.5.4",
    "vite": "^5.4.6",
    "vite-plugin-singlefile": "^2.3.3",
    "vitest": "^4.1.8",
    "wrangler": "^4.100.0"
  }
}
